# ============================================
# TASFAM Website - Environment Variables
# ============================================
# Copy this file to .env and update the values:
#   cp .env.example .env
# ============================================

# Database credentials
DB_USER=tasfam
DB_PASSWORD=change_me_strong_password

# Database URL (Prisma uses this inside Docker)
DATABASE_URL=postgresql://tasfam:change_me_strong_password@db:5432/tasfam

# Admin authentication secret
# Generate a random one with: openssl rand -base64 32
JWT_SECRET=change_me_generate_with_openssl
